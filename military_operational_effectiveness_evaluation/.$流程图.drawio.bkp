<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/26.0.9 Chrome/128.0.6613.186 Electron/32.2.5 Safari/537.36" version="26.0.9">
  <diagram name="专家可信度评估流程" id="flowchart">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- 标题 -->
        <mxCell id="title" value="军事通信效能评估 - 专家可信度与AHP权重计算流程" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry" />
        </mxCell>
        
        <!-- ==================== 输入数据 ==================== -->
        <mxCell id="input_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="280" height="160" as="geometry" />
        </mxCell>
        <mxCell id="input_title" value="输入数据" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="input1" value="• 专家背景数据&#xa;(expert_credibility_evaluation_score)&#xa;• AHP评分+把握度&#xa;(ahp_expert_military_operation_effect_weights)&#xa;• 实验数据(熵权法备用)&#xa;(equipment_operation_score)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="50" y="110" width="260" height="120" as="geometry" />
        </mxCell>
        
        <!-- 箭头: 输入 -> 步骤1 -->
        <mxCell id="arrow1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2" edge="1" parent="1" source="input_box" target="step1_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- ==================== 步骤1: 专家可信度 ==================== -->
        <mxCell id="step1_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="280" height="160" as="geometry" />
        </mxCell>
        <mxCell id="step1_title" value="步骤1: 计算专家可信度" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step1_1" value="① 主观可信度 αi&#xa;   基于专家背景计算" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="390" y="110" width="260" height="35" as="geometry" />
        </mxCell>
        <mxCell id="step1_2" value="② 客观可信度 βi&#xa;   基于评分一致性(CV)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="390" y="145" width="260" height="35" as="geometry" />
        </mxCell>
        <mxCell id="step1_3" value="③ 综合可信度 = 0.6α + 0.4β" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="390" y="180" width="260" height="35" as="geometry" />
        </mxCell>
        
        <!-- 箭头: 步骤1 -> 步骤2 -->
        <mxCell id="arrow2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2" edge="1" parent="1" source="step1_box" target="step2_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- ==================== 步骤2: 指标CV ==================== -->
        <mxCell id="step2_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="720" y="80" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="step2_title" value="步骤2: 计算指标CV" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="720" y="80" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step2_1" value="• 把握度过滤(&lt;0.6剔除)&#xa;• 计算单指标CV&#xa;• 识别全员无把握指标" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="110" width="260" height="60" as="geometry" />
        </mxCell>
        
        <!-- 箭头: 步骤2 -> 步骤3 -->
        <mxCell id="arrow3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2" edge="1" parent="1" source="step2_box" target="step3_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- ==================== 步骤3: 调整因子 ==================== -->
        <mxCell id="step3_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1060" y="80" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="step3_title" value="步骤3: 计算调整因子" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1060" y="80" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step3_1" value="qij = 0.5×(0.6αi+0.4βi) + 0.5×conf&#xa;• 把握度权重: 0.5&#xa;• 专家可信度权重: 0.5" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1070" y="110" width="260" height="60" as="geometry" />
        </mxCell>
        
        <!-- 箭头: 步骤3 -> 步骤4 -->
        <mxCell id="arrow4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2" edge="1" parent="1" source="step3_box" target="step4_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- ==================== 步骤4: AHP权重 ==================== -->
        <mxCell id="step4_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="720" y="240" width="620" height="180" as="geometry" />
        </mxCell>
        <mxCell id="step4_title" value="步骤4: AHP权重计算" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="720" y="240" width="620" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step4_1" value="① 把握度过滤(&lt;0.6剔除)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="275" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="step4_2" value="② 构建判断矩阵: 加权评分=评分×qij, 比值=加权i/加权j" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="305" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="step4_3" value="③ 离群值删除(≥3样本时删除离均值最远值)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="335" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="step4_4" value="④ 一致性检验(CR≤0.1)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="365" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="step4_5" value="⑤ 几何平均法求权重" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="395" width="200" height="25" as="geometry" />
        </mxCell>
        
        <!-- ==================== 分支: 熵权法 ==================== -->
        <mxCell id="entropy_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="380" y="280" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="entropy_title" value="全员无把握指标 → 熵权法" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="380" y="280" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="entropy_1" value="• 基于equipment_operation_score&#xa;• 数据离散程度计算熵权&#xa;• 作为备用权重方案" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="390" y="315" width="260" height="60" as="geometry" />
        </mxCell>
        
        <!-- 箭头: 步骤2 -> 熵权法 -->
        <mxCell id="arrow_entropy" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;strokeWidth=2;dashed=1" edge="1" parent="1" source="step2_box" target="entropy_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- 箭头: 熵权法 -> 步骤5 -->
        <mxCell id="arrow_entropy2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;strokeWidth=2;dashed=1" edge="1" parent="1" source="entropy_box" target="step5_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- 箭头: AHP -> 步骤5 -->
        <mxCell id="arrow5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2" edge="1" parent="1" source="step4_box" target="step5_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- ==================== 步骤5: 最终权重 ==================== -->
        <mxCell id="step5_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="720" y="480" width="620" height="120" as="geometry" />
        </mxCell>
        <mxCell id="step5_title" value="步骤5: 最终权重合成" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="720" y="480" width="620" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step5_1" value="最终权重j = 二级权重j × 一级权重k" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="520" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="step5_2" value="全局归一化: 权重之和 = 1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="550" width="600" height="25" as="geometry" />
        </mxCell>
        
        <!-- 箭头: 步骤5 -> 输出 -->
        <mxCell id="arrow_output" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2" edge="1" parent="1" source="step5_box" target="output_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- ==================== 输出 ==================== -->
        <mxCell id="output_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="720" y="660" width="620" height="140" as="geometry" />
        </mxCell>
        <mxCell id="output_title" value="输出结果" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="720" y="660" width="620" height="30" as="geometry" />
        </mxCell>
        <mxCell id="output_1" value="• 专家可信度评估结果 (α, β, 综合可信度)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="700" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="output_2" value="• 20个二级指标最终权重 (原始vs最终对比图)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="730" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="output_3" value="• 可视化图表 (旭日图、权重排名、变化幅度标注)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="730" y="760" width="600" height="25" as="geometry" />
        </mxCell>
        
        <!-- ==================== 可视化部分 ==================== -->
        <mxCell id="viz_title" value="可视化方案" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="280" height="30" as="geometry" />
        </mxCell>
        
        <!-- 图1 -->
        <mxCell id="viz1_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="40" y="315" width="130" height="90" as="geometry" />
        </mxCell>
        <mxCell id="viz1_title" value="图1: 专家可信度综合图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="40" y="315" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="viz1_1" value="3×2布局6子图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="40" y="335" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="viz1_2" value="评分折线、CV、&#xa;可信度柱状图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="40" y="355" width="130" height="40" as="geometry" />
        </mxCell>
        
        <!-- 图2 -->
        <mxCell id="viz2_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="180" y="315" width="130" height="90" as="geometry" />
        </mxCell>
        <mxCell id="viz2_title" value="图2: 专家与权重综合图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="180" y="315" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="viz2_1" value="2×2布局4子图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="180" y="335" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="viz2_2" value="可信度对比、旭日图、&#xa;权重排名、原始vs最终" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="180" y="355" width="130" height="40" as="geometry" />
        </mxCell>
        
        <!-- 关键公式 -->
        <mxCell id="formula_title" value="关键公式" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="formula_box" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="40" y="465" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="formula_1" value="αi = (Ωe + Ωk) / 100" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="475" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="formula_2" value="βi = f(CVi) 分段衰减" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="500" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="formula_3" value="综合可信度 = 0.6α + 0.4β" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="525" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="formula_4" value="qij = 0.5×(0.6α+0.4β) + 0.5×conf" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="550" width="260" height="20" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
